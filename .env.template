# CDC Environment Configuration Template
# Purpose: Configuration for CDC system deployment
# Version: 1.0.0
# Date: 2026-02-07
# Instructions: Copy to .env and fill in values

# ============================================================================
# AZURE CREDENTIALS
# ============================================================================

# Azure subscription and authentication
# Use: az account show to get subscription ID
AZURE_SUBSCRIPTION_ID=

# Use: az account show --query tenantId
AZURE_TENANT_ID=

# Azure CLI or DefaultAzureCredential will be used for authentication
# No need to set AZURE_CLIENT_ID/AZURE_CLIENT_SECRET for local dev

# ============================================================================
# COSMOS DB
# ============================================================================

# Cosmos DB endpoint for CDC containers
# Format: https://[account-name].documents.azure.com
# Example: https://marco-sandbox-cosmos.documents.azure.com
AZURE_COSMOSDB_ENDPOINT=

# Cosmos DB database name (default: cdc-jurisprudence)
AZURE_COSMOSDB_DATABASE=cdc-jurisprudence

# ============================================================================
# BLOB STORAGE
# ============================================================================

# Storage account connection string (for artifacts, checkpoints, debug)
# Use: az storage account show-connection-string --name [account] --resource-group [rg]
AZURE_STORAGE_CONNECTION_STRING=

# Storage account name
# Example: marcosand20260203
AZURE_STORAGE_ACCOUNT_NAME=

# Blob containers
AZURE_BLOB_CONTAINER_ARTIFACTS=cdc-artifacts
AZURE_BLOB_CONTAINER_CHECKPOINTS=cdc-checkpoints
AZURE_BLOB_CONTAINER_DEBUG=cdc-debug

# ============================================================================
# AZURE AI SEARCH
# ============================================================================

# Azure AI Search endpoint
# Format: https://[search-service-name].search.windows.net
# Example: https://marco-sandbox-search.search.windows.net
AZURE_SEARCH_ENDPOINT=

# Search index name for jurisprudence
AZURE_SEARCH_INDEX_NAME=index-jurisprudence

# Search key (optional - uses DefaultAzureCredential if not set)
AZURE_SEARCH_KEY=

# ============================================================================
# AZURE FUNCTIONS
# ============================================================================

# Function App name for CDC functions
# Example: marco-sandbox-func
AZURE_FUNCTION_APP_NAME=

# Resource group containing Function App
# Example: EsDAICoE-Sandbox
AZURE_RESOURCE_GROUP=

# Function App runtime stack (default: python)
AZURE_FUNCTIONS_WORKER_RUNTIME=python

# ============================================================================
# AZURE KEY VAULT
# ============================================================================

# Key Vault URL for secrets storage
# Format: https://[keyvault-name].vault.azure.net
# Example: https://marcosandkv20260203.vault.azure.net
AZURE_KEY_VAULT_URL=

# ============================================================================
# CANLII API
# ============================================================================

# CanLII API key for metadata polling
# Obtain from: https://www.canlii.org/en/info/api.html (verify current URL)
CANLII_API_KEY=

# CanLII API base URL
CANLII_API_BASE_URL=https://api.canlii.org/v1

# ============================================================================
# APPLICATION INSIGHTS
# ============================================================================

# Application Insights connection string for monitoring
# Use: az monitor app-insights component show --app [name] --resource-group [rg]
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Enable telemetry (true/false)
APPINSIGHTS_INSTRUMENTATION_ENABLED=true

# ============================================================================
# CDC CONFIGURATION
# ============================================================================

# CDC polling schedule (cron expression)
# Default: Daily at 2:00 AM UTC
CDC_POLL_SCHEDULE=0 0 2 * * *

# CDC scope ID for initial deployment
# Example: SST-GD-EN-rolling-24mo (Social Security Tribunal, General Division, English, rolling 24 months)
CDC_DEFAULT_SCOPE_ID=SST-GD-EN-rolling-24mo

# Change policy version
CDC_POLICY_VERSION=0.1.0

# ============================================================================
# DEVBOX / LOCAL DEVELOPMENT
# ============================================================================

# Local debug mode (enables mock services)
LOCAL_DEBUG=false

# Skip IMDS metadata service (for DevBox/local dev without managed identity)
AZURE_IDENTITY_EXCLUDE_MANAGED_IDENTITY_CREDENTIAL=true

# Python IO encoding (fixes Windows cp1252 UnicodeEncodeError)
PYTHONIOENCODING=utf-8

# ============================================================================
# OPTIONAL FLAGS
# ============================================================================

# Graceful fallback flags (for environments without private endpoints)
OPTIMIZED_KEYWORD_SEARCH_OPTIONAL=true
ENRICHMENT_OPTIONAL=true
LANGUAGE_DETECTION_OPTIONAL=true

# Professional Components Configuration
ENABLE_DEBUG_ARTIFACT_COLLECTOR=true
ENABLE_SESSION_MANAGER=true
ENABLE_STRUCTURED_ERROR_HANDLER=true

# Checkpoint frequency (save checkpoint every N cases processed)
SESSION_CHECKPOINT_INTERVAL=100

# ============================================================================
# DEVBOX CONTAINER SPECIFIC
# ============================================================================

# DevBox container name (for multi-container deployments)
DEVBOX_CONTAINER_NAME=cdc-devbox

# DevBox mount points
DEVBOX_WORKSPACE_PATH=/workspace
DEVBOX_LOGS_PATH=/workspace/logs
DEVBOX_DATA_PATH=/workspace/data
